COMPANY_NAME="Sainto"
SITE_NAME="Next.js Commerce"

# Copy this file to .env.local and fill in values (Next.js does not load .env.example)

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
SANITY_API_READ_TOKEN=""
SANITY_REVALIDATION_SECRET=""
STUDIO_ACCESS_SECRET=""

# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin (server — use one of the two options below)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
# Or paste the full service account JSON on one line:
# FIREBASE_SERVICE_ACCOUNT_JSON=""

# Comma-separated Firebase UIDs allowed to use /admin and update orders
ADMIN_FIREBASE_UIDS=""

# Database
MONGODB_URI=""

# Discord
DISCORD_BOT_TOKEN=""
DISCORD_WEBHOOK_URL=""
# Comma-separated Discord user IDs allowed to run bot commands
DISCORD_ADMIN_USER_IDS=""
